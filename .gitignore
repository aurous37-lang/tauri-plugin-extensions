# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Local run/diagnostic logs (e.g. run.log, evm-run.log, baseline-run.log)
*.log

# Node / pnpm
node_modules/
dist/
*.tsbuildinfo
.pnpm-store/
.npm/

# TS compile intermediates (but NOT the embedded-js output — that's committed
# so the Rust crate builds without needing pnpm install first).
js-runtime/dist/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db
desktop.ini

# Env
.env
.env.local
.env.*.local

# Fetched third-party extensions — populated by scripts/fetch-*.ps1.
# Track only the README in each directory; everything else comes from the
# extension vendor's CRX and is not ours to redistribute.
fixtures/test-extensions/phantom/*
!fixtures/test-extensions/phantom/README.md
fixtures/test-extensions/metamask/*
!fixtures/test-extensions/metamask/README.md
fixtures/test-extensions/rabby/*
!fixtures/test-extensions/rabby/README.md

# Examples that own their build artifacts (per-app node_modules, bundled
# dist/, etc.).
examples/*/node_modules/
examples/*/src-tauri/target/
examples/*/src-tauri/gen/schemas/

# The minimal-host ships a hand-written dist/ (plain HTML/CSS/JS) as its
# frontend — it is NOT a build artifact, even though the top-level `dist/`
# rule above would match. Re-include it.
!examples/minimal-host/dist/
!examples/minimal-host/dist/**

# Auto-acceptance report written by the minimal-host at runtime. Useful
# locally; not a source artifact.
examples/*/acceptance-report.json

# Plugin permissions: `default.toml` is hand-written; `autogenerated/` +
# `schemas/` are emitted by `tauri_plugin::Builder::new(COMMANDS).build()`
# on every `cargo build` — BUT they are committed anyway (matching official
# tauri-plugin repos): `cargo publish` verification rejects packages whose
# build script adds files to the source dir, so the generated files must
# ship inside the package. Content is deterministic from build.rs COMMANDS
# + default.toml, so the regeneration is an idempotent overwrite.


# Agent instruction files - local only, not part of the public repo.
CLAUDE.md
AGENTS.md
**/CLAUDE.md
**/AGENTS.md
